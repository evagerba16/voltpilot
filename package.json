{
  "name": "voltpilot",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "dev:clean": "rm -rf .next && next dev --turbopack",
    "dev:reset": "lsof -ti:3000,3001,3002 2>/dev/null | xargs kill 2>/dev/null; sleep 1; rm -rf .next && next dev --turbopack",
    "build": "next build --turbopack",
    "build:local": "VOLTPILOT_DIST_DIR=.next-build next build --turbopack",
    "start": "next start",
    "start:local": "VOLTPILOT_DIST_DIR=.next-build next start",
    "lint": "eslint",
    "db:migrate": "node scripts/apply-migrations.mjs",
    "db:verify": "node scripts/verify-migrations.mjs",
    "db:verify-rpc": "node scripts/verify-rpc.mjs",
    "db:verify-infrastructure": "node scripts/verify-infrastructure.mjs",
    "db:verify-proposals": "node scripts/verify-proposals-schema.mjs",
    "db:verify-analytics": "node scripts/verify-analytics-migration.mjs",
    "db:verify-all": "node scripts/verify-all-migrations.mjs",
    "beta:verify": "node scripts/beta-launch-verify.mjs",
    "org-cookie:verify": "node scripts/verify-organization-cookie.mjs",
    "ai:verify": "node scripts/verify-openai.mjs",
    "analytics:verify": "node scripts/verify-analytics.mjs",
    "estimates:verify": "node scripts/verify-estimate-calculations.mjs",
    "estimates:verify-backend": "node scripts/verify-estimate-backend.mjs",
    "dev:verify-cache": "node scripts/verify-dev-cache-isolation.mjs"
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "@react-pdf/renderer": "^4.5.1",
    "@supabase/ssr": "^0.12.1",
    "@supabase/supabase-js": "^2.110.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.24.0",
    "next": "15.5.20",
    "openai": "^6.46.0",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "recharts": "^3.9.2",
    "shadcn": "^4.13.0",
    "stripe": "^17.7.0",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "15.5.20",
    "pg": "^8.22.0",
    "playwright": "^1.49.1",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
